{
  "name": "echocode",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.19.6",
    "npm": "11.7.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "openapi:lint": "redocly lint docs/openapi/openapi.yaml",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run openapi:lint && npm run build",
    "firestore:emulators": "firebase emulators:start --only firestore",
    "test:firestore:rules": "firebase emulators:exec --only firestore \"npm run test:firestore:rules:run\"",
    "test:firestore:rules:run": "node tests/firestore.rules.test.mjs",
    "storage:emulators": "firebase emulators:start --only storage",
    "test:storage:rules": "firebase emulators:exec --only storage \"npm run test:storage:rules:run\"",
    "test:storage:rules:run": "node tests/storage.rules.test.mjs",
    "prepare": "husky",
    "seed:mock:submissions": "node ./scripts/seed_mock_admin_submissions.mjs",
    "seed:admin-users": "node ./scripts/seed_admin_users.mjs"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.19",
    "@vercel/speed-insights": "^1.3.1",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "motion": "^12.31.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@redocly/cli": "^1.34.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "firebase-tools": "^15.6.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
